{
  "name": "@runapi.ai/fish-audio",
  "runapi": {
    "slug": "fish-audio"
  },
  "version": "0.1.1",
  "description": "RunAPI Fish Audio SDK for speech generation in JavaScript, Python, Ruby, Go, Java, and PHP",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@runapi.ai/core": "^0.2.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "runapi",
    "runapi-ai",
    "fish-audio",
    "tts",
    "speech",
    "audio",
    "api",
    "sdk",
    "typescript",
    "python",
    "ruby",
    "golang",
    "java",
    "maven"
  ],
  "author": "RunAPI",
  "license": "Apache-2.0",
  "homepage": "https://runapi.ai/models/fish-audio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runapi-ai/fish-audio-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/runapi-ai/fish-audio-sdk/issues"
  }
}
